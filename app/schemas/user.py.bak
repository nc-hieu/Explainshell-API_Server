from pydantic import BaseModel, EmailStr, Field
from typing import Optional
from datetime import datetime

# Schema chung (Shared properties)
class UserBase(BaseModel):
    username: str = Field(..., min_length=3, max_length=50)
    email: EmailStr
    roles: Optional[str] = "user"

# Schema dùng khi tạo User mới (ví dụ: Đăng ký)
class UserCreate(UserBase):
    password: str = Field(..., min_length=6)

# Schema dùng để trả về dữ liệu (Response) - Không bao gồm password
class User(UserBase):
    id: int
    is_active: bool
    created_at: datetime

    class Config:
        from_attributes = True # Giúp Pydantic hiểu được dữ liệu từ SQLAlchemy Model